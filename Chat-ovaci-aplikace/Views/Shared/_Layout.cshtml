@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - RetroWeb</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <style>
        /* Retro font */
        import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

        body {
            background: #f2e9d8;
            font-family: 'Press Start 2P', cursive;
            font-size: 12px;
            color: #333;
        }

        /* Texturované pozadí */
        .retro-bg {
            background: repeating-linear-gradient(
                45deg,
                #f2e9d8,
                #f2e9d8 10px,
                #e8dfcf 10px,
                #e8dfcf 20px
            );
        }
        .retro-panel {
    background: #f7f1e6; /* jemná retro béžová */
    border: 4px solid #c7b198;
    box-shadow: 4px 4px 0 #8b6f47;
    padding: 15px;
    height: 100%;          /* zabere celý prostor v rámci col */
    display: flex;
    flex-direction: column;
}


        /* Navigace */
        .retro-nav {
            background: #c7b198;
            border-bottom: 4px solid #8b6f47;
            padding: 10px 20px;
        }

        .retro-nav a {
            color: #3b2f2f;
            text-decoration: none;
            margin-right: 20px;
            padding: 6px 10px;
            border: 2px solid #8b6f47;
            background: #e8dfcf;
            box-shadow: 2px 2px 0 #8b6f47;
            font-size: 10px;
        }

        .retro-nav a:hover {
            background: #d6c7b2;
            box-shadow: 1px 1px 0 #8b6f47;
            transform: translate(1px, 1px);
        }
        .logout-link {
    position: fixed;
    bottom: 10px;
    right: 10px;
    background: #c7b198;
    border: 3px solid #8b6f47;
    padding: 8px 12px;
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    color: #3b2f2f;
    text-decoration: none;
    box-shadow: 3px 3px 0 #8b6f47;
}

.logout-link:hover {
    background: #bfa588;
    box-shadow: 1px 1px 0 #8b6f47;
    transform: translate(2px, 2px);
}

        /* Profil */
        .profile-box {
            display: flex;
            align-items: center;
        }

        .profile-box img {
            width: 40px;
            height: 40px;
            border-radius: 4px;
            margin: 0px;
            margin-right: 10px;
            border: 2px solid #3b2f2f;
        }

        /* Hlavní panel */
        .main-panel {
            background: #fff;
            border: 4px solid #c7b198;
            padding: 20px;
            min-height: 80vh;
            box-shadow: 0 0 10px rgba(0,0,0,0.2);
        }

        /* Boční panely */
        .side-panel {
            min-height: 80vh;
        }

        
        .retro-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 10px;
        background: #f7f1e6;
        border: 3px solid #c7b198;
        box-shadow: 3px 3px 0 #8b6f47;
    }

    .retro-table th,
    .retro-table td {
        border: 2px solid #c7b198;
        padding: 4px 6px;
        text-align: left;
    }

    .retro-table th {
        background: #c7b198;
        color: #3b2f2f;
        text-transform: uppercase;
    }

    .retro-table tr:nth-child(even) {
        background: #e8dfcf;
    }

    .retro-badge-yes {
        background: #7acb7a;
        border: 2px solid #3b7b3b;
        padding: 1px 4px;
        box-shadow: 2px 2px 0 #3b7b3b;
        font-size: 9px;
    }

    .retro-badge-no {
        background: #f28b82;
        border: 2px solid #b23b2b;
        padding: 1px 4px;
        box-shadow: 2px 2px 0 #b23b2b;
        font-size: 9px;
    }

    </style>
</head>

<body class="retro-bg">

    <div class="container-fluid">
        <div class="row">

            <!-- Levý buffer -->
            <div class="col-2 side-panel"></div>

            <!-- Střední panel -->
            <div class="col-8">

                <!-- Navigace -->
                <nav class="retro-nav d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" asp-controller="Home">
                        <img src="/obrazek/přidatSeNaChatu.png" alt="Logo" style="width:40px; height:40px; margin-right:10px;" />
                        <span>RetroWeb</span>
                        </a>

                        <div class="ms-4">
                            <a asp-controller="" asp-action="">Domů</a>
                            @if (Context.Session.GetString("User") != null)
                            {
                                <a asp-controller="" asp-action="">Přidat se na chatu</a>
                                <a asp-controller="" asp-action="">Založit chatu</a>
                            }
                        </div>
                    </div>

                    <a asp-controller="Auth" asp-action="Login">
                    <div class="profile-box">
                            <img src="/obrazek/přidatSeNaChatu.png" alt="obrazek" />
                        <span>@(Context.Session.GetString("User") ?? "Přihlásit se")</span>
                    </div>
                    </a>
                </nav>

                <!-- Obsah stránky -->
                <main class="main-panel mt-3">
                    @RenderBody()
                </main>

            </div>

            <!-- Pravý buffer -->
            <div class="col-2 side-panel"></div>

        </div>
    </div>

    @RenderSection("Scripts", required: false)

    @if (Context.Session.GetString("User") != null)
    {
    <a asp-controller="Auth" asp-action="Logout" class="logout-link">Odhlásit se</a>
    }

</body>
</html>