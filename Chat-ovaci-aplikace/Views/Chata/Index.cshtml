@using Chat_ovaci_aplikace.Models.Chata;
@using Chat_ovaci_aplikace.Entities;
@model Chat_ovaci_aplikace.Entities.Chata;

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

@foreach(Mistnost mistnost in Model.Mistnosti)
{

    <p>Mistnost @mistnost.NazevMistnosti</p>
    <div>
    @foreach(Misto misto in mistnost.Mista)
    {            
        <div>
                <table>
                    <tr>
                @for (int i = 0; i < Model.obsazeni.Where(s => s.IdMisto == misto.IdMisto).ToList().Count; i++)
                {
                        <th>
                            @Model.obsazeni.Where(s => s.IdMisto == misto.IdMisto).ToList()[i].ucastnik.Uzivatel.Username
                        </th>
                }
                    </tr>
                </table>
        </div>
    }
    </div>
}