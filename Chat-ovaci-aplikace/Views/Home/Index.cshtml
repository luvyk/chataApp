@using System.Text.Json
@using Chat_ovaci_aplikace.Models.MainPage

@model MainPageViewModel
@{
    ViewData["Title"] = "Home Page";
}

<div class="container-fluid h-100">
    <div class="row h-100">

        <!-- Levý panel -->

        <div id="chataContainer" class="col-4 retro-panel">
            
                @foreach(ChataMainViewModel Model in Model.chatas)
                {
                <div class="retro-panel retro-bg">
                    <div class="chata-card" style="border:1px solid #ccc;padding:10px;margin:5px;font-family:sans-serif;font-size:14px;">
                        <h3 style="margin:0 0 5px 0;">@Model.JmenoChaty</h3>
                        <div><strong>Organizátor:</strong> @Model.Organizator</div>
                        <div><strong>Adresa:</strong> @Model.Ulice, @Model.PSC @Model.Mesto, @Model.Zeme</div>
                        @if (!string.IsNullOrEmpty(Model.Cast))
                        {
                            <div><strong>Část:</strong> @Model.Cast</div>
                        }
                        <div><strong>Začátek:</strong> @Model.Zacatek.ToString("dd.MM.yyyy HH:mm")</div>
                        <div><strong>Volná lůžka:</strong> @Model.volnaLuzka</div>
                        <div>
                            <strong>Účast:</strong>
                            @(Model.UcastniSe ? "účastní se" : "neúčastní se")
                            &nbsp;|&nbsp;
                            <strong>Platba:</strong>
                            @(Model.Zaplatil ? "zaplaceno" : "nezaplaceno")
                        </div>
                    </div>

                 </div>
                }
                Levý panel
        </div>

        <!-- Pravý panel rozdělený vertikálně -->
        <div class="col-8 d-flex flex-column">

            <div class="retro-panel mb-3" style="flex: 1;max-height: 100px;">

                Horní pravý panel
            </div>

            <div class="retro-panel" style="flex: 1;">
                Dolní pravý panel
            </div>

        </div>

    </div>
</div>

<script>
        
</script>